# 10+1 Protocol MCP Server — Environment Variables

# HMAC signing key file path (absolute path to .key file)
# Generate with: python -c "import secrets; open('.protocol.key','wb').write(secrets.token_bytes(32))"
PROTOCOL_HMAC_KEY_PATH=.protocol.key

# Log level for protocol server
PROTOCOL_LOG_LEVEL=INFO

# Windows Event Log registration (set to 1 to auto-register source on first run)
PROTOCOL_REGISTER_EVENT_SOURCE=1

# Agent ID for this instance (used in declarations when agent_id not specified)
PROTOCOL_DEFAULT_AGENT_ID=protocol-server
